<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        ZBioLock requires the USE_BIOMETRIC permission (API 28+).
        On older devices the library falls back to USE_FINGERPRINT automatically.
    -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!--
        Declared as a hint so the OS knows this app can utilize biometric hardware.
    -->
    <uses-feature
        android:name="android.hardware.fingerprint"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.biometrics.face"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.biometrics.iris"
        android:required="false" />
</manifest>
